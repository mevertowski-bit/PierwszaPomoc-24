---
import Main from '../components/Main.astro';
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import { getEntry } from 'astro:content';

// Próbujemy pobrać wpis bezpiecznie bez wywalania kompilatora
const entry = await getEntry('polityka', 'regulamin');

let RenderedContent = null;
let title = "Regulamin";

if (entry) {
    const rendered = await entry.render();
    RenderedContent = rendered.Content;
    if (entry.data && entry.data.title) {
        title = entry.data.title;
    }
}
---

<Layout title={`${title} | PierwszaPomoc-24`}>
	<Main>
		<Header title={title} currentPage={title} />
        
        <div class="prose max-w-4xl mx-auto px-6 overflow-visible relative mb-20 text-slate-800 prose-a:text-tactical-crimson">
            {RenderedContent ? (
                <RenderedContent />
            ) : (
                <div class="my-12 p-8 bg-slate-50 border border-slate-200 rounded-xl text-center">
                    <p class="text-slate-500 italic">Treść regulaminu serwisu oraz świadczenia usług jest w trakcie aktualizacji...</p>
                </div>
            )}
        </div>		
	</Main>
</Layout>