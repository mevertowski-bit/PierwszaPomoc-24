---
const currentYear = new Date().getFullYear();

// src/components/FooterRegions.astro
import miasta from '../content/eventy/miasta.json'
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';

import IconFB from '../components/icons/IconFB.astro';
import IconIG from '../components/icons/IconIG.astro';
import IconLN from '../components/icons/IconLN.astro';

// 1. Wyciągamy unikalne nazwy regionów i sortujemy je alfabetycznie
const regions = [...new Set(miasta.map(m => m.region))].sort();
const uslugi = await getCollection('uslugi')
---

<footer class="bg-tactical-slate text-slate-400 py-16 border-t border-tactical-crimson/30 font-sans">
  <div class="container mx-auto px-6 md:px-12">
    <div class="grid grid-cols-1 md:grid-cols-14 gap-12 mb-10">
      
      <div class="md:col-span-4 space-y-6">
        <div class="flex items-center gap-2">
            <Image
                    src="/images/pp24_white.png"
                    width={200}
                    height={100}
                    alt="Pierwsza Pomoc 24 logo"
                    class="rounded-2xl aspect-thumbnail object-cover"
                />
        </div>
        <p class="text-sm leading-relaxed max-w-xs opacity-70">
            Warsztaty dla dzieci, młodzieży (Przedszkoli, szkół podstawowych i liceów) szkolenia dla firm, korporacji instytucji publicznych oraz gabinetów stomatologicznych z zakresu pierwszej pomocy.
        </p>
        <div class="flex items-center gap-4">
                <a href="https://www.facebook.com/DruzynaRatownikaJuniora" target="_blank" class="text-tactical-text hover:text-tactical-crimson-hover transition-colors">
                    <IconFB class="w-5 h-5" />
                </a>
                <a href="https://www.instagram.com/pierwszapomoc24/" target="_blank" class="text-tactical-text hover:text-tactical-crimson-hover transition-colors">
                    <IconIG class="w-5 h-5" />
                </a>
                <a href="https://pl.linkedin.com/in/pierwszapomoc-24" target="_blank" class="text-tactical-text hover:text-tactical-crimson-hover transition-colors">
                    <IconLN class="w-5 h-5" />
                </a>
            </div>
      </div>

        <div class="md:col-span-2 space-y-4">
            <h4 class=" font-mono text-xs uppercase tracking-widest border-b border-tactical-crimson/50 pb-2 inline-block">Firma</h4>
            <ul class="space-y-2 text-sm">
                <li><a href="/o-nas" class="hover:text-white transition-colors">O nas</a></li>
                <li><a href="/uslugi" class="hover:text-white transition-colors">Uslugi</a></li>
                <li><a href="/kpp" class="hover:text-white transition-colors">Szkolenia KPP</a></li>
                <li><a href="/eventy" class="hover:text-white transition-colors">Eventy</a></li>
                <li><a href="/blog" class="hover:text-white transition-colors">Blog</a></li>
                <li><a href="/sklep" class="hover:text-white transition-colors">Sklep</a></li>
                <li><a href="/kontakt" class="hover:text-white transition-colors">Kontakt</a></li>
            </ul>
        </div>

      <div class="md:col-span-4 space-y-4">
        <h4 class=" font-mono text-xs uppercase tracking-widest border-b border-tactical-crimson/50 pb-2 inline-block">Szkolenia</h4>
        <ul class="space-y-2 text-sm">
          {uslugi.map((usluga) => (
            <li><a 
                href=`/uslugi/${usluga.id}/` 
                class="hover:text-white transition-colors">
                  {usluga.data.title}
                </a>
            </li>
          ))}
        </ul>
      </div>

      <div class="md:col-span-4 space-y-6">
        <h4 class=" font-mono text-xs uppercase tracking-widest border-b border-tactical-crimson/50 pb-2 inline-block">Kontakt operacyjny</h4>
        <div class="space-y-4 font-mono">
            <div class="flex flex-col">
                <span class="text-[10px] text-tactical-crimson uppercase">Tel.</span>
                <a href="tel:+48505742788" class=" text-lg hover:underline">+48 505 742 788</a>
            </div>
            <div class="flex flex-col">
                <span class="text-[10px] text-tactical-crimson uppercase">E-mail</span>
                <a href="mailto:biuro@pierwszapomoc-24.pl" class=" hover:underline lowercase">biuro@pierwszapomoc-24.pl</a>
            </div>
        </div>
      </div>

    </div>

    <div class="grid grid-cols-1 md:grid-cols-14 gap-12">
      {regions.map((region) => (
        <div class="md:col-span-2 space-y-4">
          <h4 class=" font-mono text-xs uppercase tracking-widest border-b border-tactical-crimson/50 pb-2 inline-block">{region}</h4>
          <ul class="space-y-2 text-sm">
            {miasta
                .filter(m => m.region === region) // Filtrujemy miasta tylko z tego regionu
                .sort((a, b) => a.city.localeCompare(b.city)) // Sortujemy miasta alfabetycznie
                .map((m) => (
                <li>
                  <a 
                    href={`/eventy/kurs-pierwszej-pomocy-${m.slug}`}
                    class="hover:text-white transition-colors text-sm duration-200 flex items-center gap-2 group"
                  >
                    {m.city}
                  </a>
                </li>
              ))}
          </ul>
        </div>   
      ))}
    </div>

    <div class="mt-16 pt-8 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-4 text-[10px] uppercase tracking-widest opacity-40">
      <p>&copy; {currentYear} PierwszaPomoc-24. System Status: <span class="text-green-500">Online</span></p>
      <div class="flex gap-6">
        <a href="/polityka" class="hover:text-white">Polityka prywatności</a>
        <a href="/regulamin" class="hover:text-white">Regulamin</a>
      </div>
    </div>


  </div>
</footer>