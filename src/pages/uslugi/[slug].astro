---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import TrustSection from '../../components/TrustSection.astro';
import ContactForm from '../../components/ContactForm.astro';
import DlaczegoMy from '../../components/DlaczegoMy.astro';

export async function getStaticPaths() {
    const uslugi = await getCollection("uslugi");
    return uslugi.map(usluga => ({
        params: {slug: usluga.id},
        props: {usluga}
    }));
};

const allServices = await getCollection("uslugi");

type Props = {
    usluga: CollectionEntry<"uslugi">
};

const {usluga} = Astro.props;
const {Content} = await render(usluga);

const otherServices = allServices
  .filter(item => item.id !== usluga.id);

---

<Layout title={`${usluga.data.title} | Ratownik24`}>
  <section class="bg-tactical-slate pt-16 pb-16 px-6 border-b border-white/5">
    <div class="max-w-7xl mx-auto">
      <h1 class="text-4xl md:text-7xl font-black text-white uppercase tracking-tighter leading-none mb-6">
        {usluga.data.title}
        <!-- Kurs Pierwszej Pomocy <br />
        <span class="text-tactical-crimson">{usluga.data.title}</span> -->
      </h1>
      
      <nav class="flex items-center gap-2 text-[10px] font-mono uppercase tracking-[0.2em] text-slate-500">
        <a href="/" class="hover:text-white transition-colors">Strona Główna</a>
        <span>>></span>
        <span class="text-tactical-crimson">Pierwsza Pomoc {usluga.data.title}</span>
      </nav>
    </div>
  </section>

  <section class="py-20 px-6 bg-white">
    <div class="max-w-7xl mx-auto grid lg:grid-cols-12 gap-16">
      
      <div class="lg:col-span-7 space-y-8">
        <div class="prose prose-slate max-w-none">
          <h2 class="text-3xl font-black uppercase text-slate-900 tracking-tight mb-6">
            {usluga.data.title}
          </h2>
          <p class="text-lg text-slate-600 leading-relaxed">

            <Content />
            
          </p>
        </div>
      </div>

      <div class="lg:col-span-5 relative">
        <div class="sticky top-30">

          <ContactForm theme="dark" size="small"/>
          
        </div>
      </div>
    </div>
  </section>

  <TrustSection />

  <DlaczegoMy />

  <section class="py-16 px-6 bg-slate-950 text-white">
    <div class="max-w-7xl mx-auto">
      <h3 class="text-xs font-mono uppercase tracking-[0.3em] text-tactical-crimson mb-8">// Inne szkolenia: </h3>
      <div class="flex flex-wrap gap-x-8 gap-y-4">
        {otherServices.map(item => (
          <a href={`/uslugi/${item.id}`} class="text-slate-400 hover:text-white transition-colors text-sm uppercase font-bold tracking-tighter">
            {item.data.title}
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>

