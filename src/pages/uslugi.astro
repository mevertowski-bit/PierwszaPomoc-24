---
import { getEntry } from 'astro:content';
import SubpageLayout from '../layouts/SubpageLayout.astro';

// Bezpieczne pobieranie wpisu bez wymuszania wykrzyknikiem (!)
const entry = await getEntry('templates', 'uslugi');

// Sprawdzamy, czy szablon w ogóle istnieje, zanim wywołamy .render()
let Content = null;
if (entry) {
    const rendered = await entry.render();
    Content = rendered.Content;
}
---
<SubpageLayout title="Usługi z pierwszą pomocą" currentPage='Usługi'>

  {Content ? <Content /> : <p class="text-slate-400 italic p-8 bg-slate-900/50 rounded-lg text-center">Oferta naszych usług jest w trakcie przygotowania...</p>}
  
</SubpageLayout>