---
import miasta from '../../content/eventy/miasta.json'
import { getEntry } from 'astro:content';
import SubpageLayout from '../../layouts/SubpageLayout.astro';


export async function getStaticPaths() {
    return miasta.map((miasto) => {
        return {
            params: { slug: miasto.slug },
            props: { info: miasto}
        };
    });
};

const { info } = Astro.props;
const entry = await getEntry('templates', 'kurs-kpp');
const { Content } = await entry!.render();

const otherCitiesInRegion = miasta
  .filter(m => m.region === info.region && m.slug !== info.slug)

---

<SubpageLayout title={`Kurs Pierwszej Pomocy`} currentPage=`Pierwsza Pomoc ${info.city}` city=`${info.city}`>

  <h2 slot="before-content" class="text-3xl font-black uppercase text-slate-900 tracking-tight mb-12">
    Kurs pierwszej pomocy w {info.cityVariant}
  </h2>

  <Content />



  <section slot="after-content" class="py-16 px-6 bg-slate-950 text-white">
    <div class="max-w-7xl mx-auto">
      <h3 class="text-xs font-mono uppercase tracking-[0.3em] text-tactical-crimson mb-8">// Inne lokalizacje: {info.region}</h3>
      <div class="flex flex-wrap gap-x-8 gap-y-4">
        {otherCitiesInRegion.map(m => (
          <a href={`/eventy/kurs-pierwszej-pomocy-${m.slug}`} class="text-slate-400 hover:text-white transition-colors text-sm uppercase font-bold tracking-tighter">
            {m.city}
          </a>
        ))}
      </div>
    </div>
  </section>
  
</SubpageLayout>
