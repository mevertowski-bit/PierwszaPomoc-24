<section class="py-12 bg-white overflow-hidden">
  {/* GÓRNA CZĘŚĆ - Ograniczona do 7xl */}
  <div class="max-w-7xl mx-auto px-6 mb-12">
    <div class="mb-16 border-l-8 border-tactical-crimson pl-8">
      <h2 class="text-4xl md:text-5xl font-black uppercase text-slate-900 tracking-tighter italic">
        Najwyższy Standard <br /> Szkoleń Ratowniczych
      </h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 border-t border-l border-slate-100">
      {newFeatures.map((f) => (
        <div class="p-8 border-r border-b border-slate-100 hover:bg-slate-50 transition-all group relative">
          <div class="w-10 h-10 text-tactical-crimson mb-6 group-hover:scale-110 transition-transform duration-300">
            <Fragment set:html={f.icon} />
          </div>
          
          <h3 class="font-black uppercase text-sm tracking-tight text-slate-900 mb-3">
            {f.title}
          </h3>
          <p class="text-xs text-slate-500 leading-relaxed font-medium">
            {f.desc}
          </p>

          <div class="absolute bottom-0 right-0 w-0 h-0 border-style-solid border-t-[10px] border-t-transparent border-r-[10px] border-r-slate-200 group-hover:border-r-tactical-crimson transition-colors"></div>
        </div>
      ))}
    </div>
  </div>

  {/* DOLNY PASEK - Pełna szerokość strony */}
  <div class="bg-slate-900 w-full py-10 px-6">
    <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between gap-8">
      <div class="text-center md:text-left">
        <p class="text-tactical-crimson font-mono text-[10px] uppercase tracking-widest mb-1 italic font-bold">// Działamy w całej Polsce</p>
        <p class="text-2xl md:text-3xl font-black text-white uppercase tracking-tighter italic">Gotowy na szkolenie w Twoim mieście?</p>
      </div>
      <a href="/kontakt" class="w-full md:w-auto text-center px-10 py-5 bg-tactical-crimson text-white font-black uppercase text-xs tracking-[0.2em] hover:bg-white hover:text-black transition-all">
        Skontaktuj się
      </a>
    </div>
  </div>
</section>