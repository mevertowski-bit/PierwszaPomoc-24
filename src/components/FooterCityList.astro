---
// src/components/FooterRegions.astro
import miasta from '../content/eventy/miasta.json'

// 1. Wyciągamy unikalne nazwy regionów i sortujemy je alfabetycznie
const regions = [...new Set(miasta.map(m => m.region))].sort();
---

<footer class="bg-slate-950 text-white pt-16 pb-8 px-6 border-t border-white/5">
  <div class="max-w-7xl mx-auto">
    
    <div class="mb-12">
      <h2 class="text-tactical-crimson font-mono text-xs tracking-[0.3em] font-bold mb-6 uppercase">
        // Nasze obszary operacyjne
      </h2>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
        {regions.map((region) => (
          <div class="space-y-4">
            <h3 class="text-white font-bold text-sm uppercase tracking-tighter border-b border-white/10 pb-2">
              Woj. {region}
            </h3>
            <ul class="space-y-2">
              {miasta
                .filter(m => m.region === region) // Filtrujemy miasta tylko z tego regionu
                .sort((a, b) => a.city.localeCompare(b.city)) // Sortujemy miasta alfabetycznie
                .map((m) => (
                <li>
                  <a 
                    href={`/kurs-pierwszej-pomocy-${m.slug}`}
                    class="text-slate-500 hover:text-white text-sm transition-colors duration-200 flex items-center gap-2 group"
                  >
                    <span class="w-1 h-1 bg-tactical-crimson opacity-0 group-hover:opacity-100 transition-opacity"></span>
                    {m.city}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>

    <div class="pt-8 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-4 text-[10px] font-mono text-slate-600 uppercase">
      <p>&copy; {new Date().getFullYear()} Ratownik24. Wszystkie uprawnienia zastrzeżone.</p>
      <div class="flex gap-6">
        <a href="/polityka-prywatnosci" class="hover:text-white transition-colors">Polityka Prywatności</a>
        <span>Status: Online</span>
      </div>
    </div>
  </div>
</footer>