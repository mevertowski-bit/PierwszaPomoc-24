  { icon: icons.users, title: "Standard Grupy", desc: "Max. 12-15 osób na jednego trenera. Gwarancja uwagi dla każdego." },
  { icon: icons.heart, title: "System QCPR", desc: "Analiza jakości uciśnięć w czasie rzeczywistym na fantomach Laerdal." },
  { icon: icons.shield, title: "Realne Scenariusze", desc: "Od krwotoków po stany nagłe (udar, zawał, epilepsja)." },
  { icon: icons.map, title: "Dojazd Gratis", desc: "Warszawa, Olsztyn, Gdańsk, Katowice i Kraków – do 50km dojazd 0 zł." },
  { icon: icons.zap, title: "Szybka Reakcja", desc: "Uczymy obsługi AED, rolowania i technik wyciągania z auta." },
  { icon: icons.grad, title: "Czynni Ratownicy", desc: "Szkolenia prowadzone przez praktyków z wieloletnim stażem." },
  { icon: icons.price, title: "Wycena Custom", desc: "Potrzebujesz oferty dla firmy lub szkoły? Napisz do nas!" }
