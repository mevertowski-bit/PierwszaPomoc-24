---

const features = [
  { title: "Kadra Operacyjna", desc: "Szkolenia prowadzą wyłącznie czynni ratownicy medyczni i strażacy PSP." },
  { title: "Standard ERC 2025", desc: "Program oparty na najnowszych wytycznych Europejskiej Rady Resuscytacji." },
  { title: "Sprzęt Premium", desc: "Pracujemy na fantomach Laerdal z systemem QCPR monitorującym jakość RKO." },
  { title: "Redukcja Krwotoków", desc: "Nauczymy Cię obsługi staz taktycznych CAT zgodnie z protokołami pola walki." },
  { title: "Realistyczne Pozoracje", desc: "Wykorzystujemy charakteryzację medyczną, aby oswoić Cię ze stresem ratowniczym." },
  { title: "System AED Expert", desc: "Każdy uczestnik wykonuje min. 10 pełnych cykli pracy z defibrylatorem." },
  { title: "Zasada 80/20", desc: "Ograniczamy wykłady. 80% czasu to intensywne ćwiczenia praktyczne i symulacje." },
  { title: "Dynamika Działania", desc: "Uczymy jak przejąć dowodzenie i zarządzać tłumem w sytuacji kryzysowej." },
  { title: "Logistyka Mobilna", desc: "Własne zaplecze treningowe rozstawiamy bezpośrednio w Twojej lokalizacji." },
  { title: "Scenariusze Stress-Test", desc: "Egzamin w formie symulacji sprawdzającej Twoje reakcje pod presją czasu." },
  { title: "Aspekty Prawne", desc: "Wyjaśniamy zawiłości prawne, budując pewność Twoich działań ratunkowych." },
  { title: "Raport Pooperacyjny", desc: "Szczegółowa analiza kompetencji grupy dla managera lub właściciela firmy." }
];
---


<section class="py-24 px-6 bg-slate-50">
    <div class="max-w-7xl mx-auto text-center mb-16">
      <h2 class="text-4xl font-black uppercase text-slate-900 tracking-tighter">Dlaczego my?</h2>
      <div class="w-20 h-1 bg-tactical-crimson mx-auto mt-4"></div>
    </div>
    <div class="max-w-7xl mx-auto grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
      {features.map((_, i) => (
        <div class="bg-white p-6 border border-slate-200 hover:border-tactical-crimson transition-colors group">
          <span class="text-tactical-crimson font-mono text-[10px] block mb-2">// 0{i+1}</span>
          <h4 class="font-bold text-slate-900 uppercase text-xs tracking-widest mb-2 group-hover:text-tactical-crimson">{_.title}</h4>
          <p class="text-[11px] text-slate-500 leading-tight">{_.desc}</p>
        </div>
      ))}
    </div>
</section>