---
import Layout from '../../layouts/Layout.astro';
import miasta from '../../content/eventy/miasta.json'
import { Image } from 'astro:assets';
import { getEntry, render } from 'astro:content';
import TrustSection from '../../components/TrustSection.astro';
import ContactForm from '../../components/ContactForm.astro';
import DlaczegoMy from '../../components/DlaczegoMy.astro';


export async function getStaticPaths() {
    return miasta.map((miasto) => {
        return {
            params: { slug: miasto.slug },
            props: { info: miasto}
        };
    });
};

const { info } = Astro.props;
const entry = await getEntry('templates', 'kurs-kpp');
const { Content } = await entry!.render();

const otherCitiesInRegion = miasta
  .filter(m => m.region === info.region && m.slug !== info.slug)

---


